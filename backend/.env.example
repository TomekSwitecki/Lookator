# Backend environment variables.
# Copy to backend/.env only for local manual runs.
# On Railway, add these in the backend service Variables panel.

# Railway Postgres usually gives you host, port, database, user, and password.
# Spring Boot needs the JDBC form:
# jdbc:postgresql://HOST:PORT/DATABASE
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:PORT/DATABASE
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-your-password

LOOKATOR_JWT_SECRET=replace-with-a-long-random-production-secret
PORT=8080
LOOKATOR_ALLOWED_ORIGINS=http://localhost:5173,https://lookator.onrender.com

# Optional
LOOKATOR_OVERPASS_URL=https://overpass-api.de/api/interpreter
