# Copy this file to .env only for local manual runs.
# For Railway, set the same variables in the Railway service Variables panel.

SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:PORT/DATABASE
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-your-password

LOOKATOR_JWT_SECRET=change-this-to-a-long-random-secret
PORT=8080
LOOKATOR_ALLOWED_ORIGINS=http://localhost:5173,https://lookator.onrender.com
